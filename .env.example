# 复制本文件为 .env.local 并填入你的 Supabase 项目值。

# --- 浏览器可见(公开) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 服务端专用(切勿暴露到浏览器) ---
# service_role 密钥:运行时写缓存/记忆用(绕过 RLS)。
SUPABASE_SERVICE_ROLE_KEY=

# 数据库直连串(仅建表脚本 scripts/db-setup.mjs 用,执行 DDL)。
# Supabase Dashboard → Settings → Database → Connection string(URI 格式,含密码)。
DATABASE_URL=
