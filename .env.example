# 复制本文件为 .env.local 并填入你的 Supabase 项目值。

# --- 浏览器可见(公开) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 服务端专用(切勿暴露到浏览器) ---
# service_role 密钥:运行时写缓存/记忆用(绕过 RLS)。
SUPABASE_SERVICE_ROLE_KEY=

# 数据库直连串(仅建表脚本 scripts/db-setup.mjs 用,执行 DDL)。
# Supabase Dashboard → Settings → Database → Connection string(URI 格式,含密码)。
DATABASE_URL=

# --- AI 模型 Key(阶段 3 引擎调用) ---
# 多 Key 轮换:逗号分隔多把。可给每把加备注标签,格式 "标签=key"(日志显示标签,不显示完整 key)。
#   例:DEEPSEEK_API_KEY=主账号=sk-aaa,备用=sk-bbb
# 国产三家(OpenAI 兼容接口)
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MOONSHOT_API_KEY=
# 海外(强模型环节:L2.5 辩论 / L3 仲裁,默认 Sonnet 4.6)
ANTHROPIC_API_KEY=
# 可选:覆盖各家默认模型名(国产默认模型名若与你账号不符,在此指定真实名称)
# DEEPSEEK_MODEL=deepseek-chat
# MINIMAX_MODEL=
# MOONSHOT_MODEL=
# ANTHROPIC_MODEL=claude-sonnet-4-6
